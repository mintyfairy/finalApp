<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fa.plus.admin.mapper.CampAdminMapper">
	<!-- 캠핑장 등록 -->
	<select id="SiteSeq" resultType="Long">
		SELECT CAMPINGSITE_SEQ.NEXTVAL FROM dual
	</select>
	
	<insert id="insertSite" parameterType="com.fa.plus.domain.site.Site">
	insert into campingsite(SITENUM,SITENAME,INTODUCE,SITELOCAL,ZIP,addr1,addr2,
	 THUMBNAIL,CATEGORY,ENVIRONMENT,HITCOUNT,CHECKIN,CHKOUT,
	  MEMBERIDX,AVGSTAR,SITEOPTION,ENABLED)
		
		values(#{SITENUM}, #{SITENAME}, #{INTODUCE}, #{SITELOCAL}, #{ZIP}, #{addr1}, #{addr2},
		 #{THUMBNAIL}, #{CATEGORY}, #{ENVIRONMENT}, 0 , #{CHECKIN}, #{CHKOUT},
		  #{MEMBERIDX}, 0 , #{SITEOPTION,jdbcType=VARCHAR}, 0);
	
		
	</insert>
	
	<!-- 추가 이미지 등록 -->
	<insert id="insertSiteFile" parameterType="com.fa.plus.domain.site.Site">
		INSERT INTO sitePic(SPICNUM, SITENUM, filename)
			VALUES(SITEPIC_SEQ.NEXTVAL, #{SITENUM}, #{filename})
	</insert>

		
	<select id="dataCountSite" parameterType="map" resultType="Integer">
		SELECT NVL(COUNT(*), 0)
		FROM campingsite p
	</select>
	
	<!-- 방 등록 -->
	<select id="RoomSeq" resultType="Long">
		SELECT CAMPINGSITE_SEQ.NEXTVAL FROM dual
	</select>
	
	<insert id="insertRoom" parameterType="com.fa.plus.domain.site.SiteDetial">
	insert into campingsite(SITENUM,SITENAME,INTODUCE,SITELOCAL,ZIP,addr1,addr2,
	 THUMBNAIL,CATEGORY,ENVIRONMENT,HITCOUNT,CHECKIN,CHKOUT,
	  MEMBERIDX,AVGSTAR,SITEOPTION,ENABLED)
		
		values(#{SITENUM}, #{SITENAME}, #{INTODUCE}, #{SITELOCAL}, #{ZIP}, #{addr1}, #{addr2},
		 #{THUMBNAIL}, #{CATEGORY}, #{ENVIRONMENT}, 0 , #{CHECKIN}, #{CHKOUT},
		  #{MEMBERIDX}, 0.0 , #{SITEOPTION}, 0);
	
		
	</insert>
	
	<!-- 추가 이미지 등록 -->
	<insert id="insertRoomFile" parameterType="com.fa.plus.domain.site.SiteDetial">
		INSERT INTO sitePic(SPICNUM, SITENUM, filename)
			VALUES(SITEPIC_SEQ.NEXTVAL, #{SITENUM}, #{filename})
	</insert>

		
	<select id="dataCountSite" parameterType="map" resultType="Integer">
		SELECT NVL(COUNT(*), 0)
		FROM campingsite p
	</select>
	
	
	<!-- 리스트 -->
	<select id="listSite" parameterType="map" resultType="com.fa.plus.domain.site.Site">
		SELECT p.productNum, categoryNum, productName, price, discountRate,
			thumbnail, productShow, reg_date, TO_CHAR(update_date, 'YYYY-MM-DD') update_date, 
			NVL(totalStock, 0) totalStock
		FROM product p
		LEFT OUTER JOIN (
			SELECT productNum, NVL(SUM(totalStock), 0) totalStock
			FROM productStock
			GROUP BY productNum
		) t ON p.productNum = t.productNum
		<where>
			special = #{special}
			<if test="categoryNum != 0">
				AND p.categoryNum = #{categoryNum}
			</if>
			<if test="productShow != -1">
				AND productShow = #{productShow}
			</if>
			<if test="kwd != null and kwd != '' ">
				AND <include refid="where-list"/>
			</if>
		</where>
		ORDER BY p.productNum DESC
		OFFSET #{offset} ROWS FETCH FIRST #{size} ROWS ONLY
	</select>


	<update id="updateSite" parameterType="com.fa.plus.domain.site.Site">
		UPDATE product SET categoryNum = #{categoryNum}, productName = #{productName},
			price = #{price}, discountRate = #{discountRate}, savedMoney = #{savedMoney},
			delivery = #{delivery}, content = #{content}, thumbnail = #{thumbnail},
			productShow = #{productShow}, update_date = SYSDATE
		WHERE productNum = #{productNum}
	</update>

	<delete id="deleteSite" parameterType="Long">
		DELETE FROM product WHERE productNum = #{productNum}
	</delete>
	
	<delete id="deleteSiteFile" parameterType="Long">
		DELETE FROM productFile WHERE fileNum = #{fileNum}
	</delete>

	
	
</mapper>